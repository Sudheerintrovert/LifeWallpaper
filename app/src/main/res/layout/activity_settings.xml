<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Life Wallpaper Settings"
            android:textSize="22sp"
            android:textColor="#e0e0e0"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="32dp" />

        <!-- Birth Date -->
        <TextView
            android:id="@+id/label_birth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date of Birth"
            android:textSize="13sp"
            android:textColor="#e0e0e0"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/input_birth"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@android:color/transparent"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:inputType="date"
            android:hint="2000-01-01"
            android:textColorHint="#444444"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Goal Date -->
        <TextView
            android:id="@+id/label_goal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goal Deadline"
            android:textSize="13sp"
            android:textColor="#e0e0e0"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/input_goal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@android:color/transparent"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:inputType="date"
            android:hint="2030-12-31"
            android:textColorHint="#444444"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Goal Text -->
        <TextView
            android:id="@+id/label_goal_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goal Text"
            android:textSize="13sp"
            android:textColor="#e0e0e0"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/input_goal_text"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@android:color/transparent"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:hint="Build My Dream Career"
            android:textColorHint="#444444"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Dark Theme -->
        <Switch
            android:id="@+id/toggle_dark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AMOLED Dark Theme"
            android:textColor="#e0e0e0"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Text Color -->
        <Button
            android:id="@+id/btn_text_color"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Text Color: White"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Font Size -->
        <TextView
            android:id="@+id/label_font"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Font Size"
            android:textSize="13sp"
            android:textColor="#e0e0e0"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />
        <SeekBar
            android:id="@+id/slider_font_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="24"
            android:max="96"
            android:progress="48"
            android:layout_marginBottom="4dp" />
        <TextView
            android:id="@+id/label_font_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="48px"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp" />

        <!-- Font Family -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Font Family"
            android:textSize="13sp"
            android:textColor="#e0e0e0"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />
        <RadioGroup
            android:id="@+id/radio_font"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <RadioButton android:id="@+id/font_sans" android:text="Sans" android:textColor="#ccc" android:checked="true" />
            <RadioButton android:id="@+id/font_serif" android:text="Serif" android:textColor="#ccc" />
            <RadioButton android:id="@+id/font_mono" android:text="Mono" android:textColor="#ccc" />
        </RadioGroup>

        <!-- Divider Style -->
        <TextView
            android:id="@+id/label_divider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Divider Style"
            android:textSize="13sp"
            android:textColor="#e0e0e0"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />
        <RadioGroup
            android:id="@+id/radio_divider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <RadioButton android:id="@+id/div_thin" android:text="Thin" android:textColor="#ccc" android:checked="true" />
            <RadioButton android:id="@+id/div_dashed" android:text="Dashed" android:textColor="#ccc" />
            <RadioButton android:id="@+id/div_gradient" android:text="Gradient" android:textColor="#ccc" />
        </RadioGroup>

        <!-- Breathing Effect -->
        <TextView
            android:id="@+id/label_effects"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Effects"
            android:textSize="13sp"
            android:textColor="#e0e0e0"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />
        <Switch
            android:id="@+id/toggle_breathe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Breathing effect for goal text"
            android:textColor="#e0e0e0"
            android:textSize="14sp"
            android:checked="true"
            android:layout_marginBottom="32dp" />

        <!-- Preview -->
        <TextView
            android:id="@+id/preview"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#1a1a1a"
            android:gravity="center"
            android:text="Preview"
            android:textSize="20sp"
            android:textColor="#ffffff"
            android:layout_marginBottom="24dp" />

        <!-- Save -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save &amp; Apply Wallpaper"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
