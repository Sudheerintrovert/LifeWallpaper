<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:id="@+id/settings_root" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#111111" android:padding="24dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Life Wallpaper Settings" android:textSize="22sp" android:textColor="#e0e0e0" android:fontFamily="sans-serif-light" android:layout_marginBottom="28dp"/>

        <!-- Birth Date -->
        <TextView android:id="@+id/label_birth" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DATE OF BIRTH" android:textSize="12sp" android:textColor="#e0e0e0" android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/input_birth" android:layout_width="match_parent" android:layout_height="52dp" android:background="@android:color/transparent" android:textColor="#ffffff" android:textSize="16sp" android:inputType="date" android:hint="2000-01-01" android:textColorHint="#444444" android:paddingHorizontal="16dp" android:layout_marginBottom="28dp"/>

        <!-- Active Goals Section -->
        <TextView android:id="@+id/label_goals" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ACTIVE GOALS" android:textSize="12sp" android:textColor="#e0e0e0" android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="12dp"/>

        <LinearLayout android:id="@+id/goals_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="16dp"/>

        <!-- Add New Goal Button -->
        <Button android:id="@+id/btn_add_goal" android:layout_width="match_parent" android:layout_height="52dp" android:text="+ Add New Goal" android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="24dp"/>

        <!-- Reached Goals Section -->
        <LinearLayout android:id="@+id/reached_section" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
            <TextView android:id="@+id/reached_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REACHED GOALS (0)" android:textSize="12sp" android:textColor="#4caf50" android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="12dp"/>
            <LinearLayout android:id="@+id/reached_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="24dp"/>
        </LinearLayout>

        <!-- Appearance Settings -->
        <Switch android:id="@+id/toggle_dark" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="AMOLED Dark Theme" android:textColor="#e0e0e0" android:textSize="14sp" android:layout_marginBottom="20dp"/>
        <Button android:id="@+id/btn_text_color" android:layout_width="match_parent" android:layout_height="52dp" android:text="Text Color: White" android:textSize="14sp" android:layout_marginBottom="20dp"/>

        <TextView android:id="@+id/label_font" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FONT SIZE" android:textSize="12sp" android:textColor="#e0e0e0" android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <SeekBar android:id="@+id/slider_font_size" android:layout_width="match_parent" android:layout_height="wrap_content" android:min="24" android:max="96" android:progress="48" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/label_font_size" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="48px" android:textSize="12sp" android:textColor="#888888" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FONT FAMILY" android:textSize="12sp" android:textColor="#e0e0e0" android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <RadioGroup android:id="@+id/radio_font" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="20dp">
            <RadioButton android:id="@+id/font_sans" android:text="Sans" android:textColor="#ccc" android:checked="true"/>
            <RadioButton android:id="@+id/font_serif" android:text="Serif" android:textColor="#ccc"/>
            <RadioButton android:id="@+id/font_mono" android:text="Mono" android:textColor="#ccc"/>
        </RadioGroup>

        <TextView android:id="@+id/label_divider" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DIVIDER STYLE" android:textSize="12sp" android:textColor="#e0e0e0" android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <RadioGroup android:id="@+id/radio_divider" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="20dp">
            <RadioButton android:id="@+id/div_thin" android:text="Thin" android:textColor="#ccc" android:checked="true"/>
            <RadioButton android:id="@+id/div_dashed" android:text="Dashed" android:textColor="#ccc"/>
            <RadioButton android:id="@+id/div_gradient" android:text="Gradient" android:textColor="#ccc"/>
        </RadioGroup>

        <TextView android:id="@+id/label_effects" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EFFECTS" android:textSize="12sp" android:textColor="#e0e0e0" android:textAllCaps="true" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Switch android:id="@+id/toggle_breathe" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Breathing effect for goal text" android:textColor="#e0e0e0" android:textSize="14sp" android:checked="true" android:layout_marginBottom="20dp"/>

        <TextView android:id="@+id/preview" android:layout_width="match_parent" android:layout_height="60dp" android:background="#1a1a1a" android:gravity="center" android:text="Preview" android:textSize="20sp" android:textColor="#ffffff" android:layout_marginBottom="20dp"/>

        <Button android:id="@+id/btn_save" android:layout_width="match_parent" android:layout_height="56dp" android:text="Save &amp; Apply Wallpaper" android:textSize="16sp" android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>